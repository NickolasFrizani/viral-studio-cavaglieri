# ─── Gemini API (para geração de estratégia e storyboard) ───────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Google Cloud / Vertex AI (para Veo3) ───────────────────────────────────
# Seu Project ID no Google Cloud Console
GOOGLE_CLOUD_PROJECT_ID=viraliavideoscavaglieri

# Região (us-central1 tem melhor suporte ao Veo3)
GOOGLE_CLOUD_LOCATION=us-central1

# Modelo Veo3
VEO_MODEL_ID=veo-3.0-generate-preview

# ─── Service Account (credenciais do arquivo JSON baixado) ──────────────────
# Cole os valores do arquivo viraliavideoscavaglieri-xxxx.json aqui:
GOOGLE_PRIVATE_KEY_ID=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=vertex-express@viraliavideoscavaglieri.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=

# ─── Google OAuth (para salvar no Drive) ────────────────────────────────────
# Crie em: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── App Config ─────────────────────────────────────────────────────────────
# URL onde o app está rodando (em produção, sua URL do Vercel)
APP_URL=https://viral-studio-cavaglieri.vercel.app
